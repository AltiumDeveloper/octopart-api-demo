@page "/"
@inherits AbstractPage

<br />
<MudForm>
    <MudCard>
        <MudCardContent>
            <MudText Typo=Typo.h4 GutterBottom=true>Connect</MudText>
            <MudText>Don't have a token? See <MudLink Href="https://github.com/AltiumDeveloper/octopart-api-demo#readme" Target="_blank">README</MudLink></MudText>
            <MudTextField @bind-Value=@_token
                          Label="Access token"
                          Variant=Variant.Outlined
                          Adornment=Adornment.Start
                          AdornmentIcon=@Icons.Material.Filled.ContentPaste
                          OnAdornmentClick="PasteToken" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Color=Color.Primary OnClick=@ConnectAsync>Connect</MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>

@if (_connecting)
{
    <MudProgressLinear Indeterminate=true />
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? TokenParameter { get; init; }
    
    string? _token;
    bool _connecting;
    
    /// <summary>
    /// Connect with the input token.
    /// </summary>
    async Task ConnectAsync()
    {
        if (string.IsNullOrEmpty(_token))
            return;

        _connecting = true;
        try
        {
            AppData.Token = _token; 
            NavManager.NavigateTo("search");
        }
        catch (Exception ex)
        {
            await ShowErrorAndResetAsync(ex.Message);
        }
        finally
        {
            _connecting = false;
        }
    }

    /// <summary>
    /// If a token is provided, check its sanity, then go to search.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        // skip started
        if (AppData.Token != null)
            return;

        try
        {
            if (TokenParameter is not null)
            {
                try
                {
                    var tokenHandler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
                    var jwtSecurityToken = tokenHandler.ReadJwtToken(TokenParameter);
                    if (jwtSecurityToken.ValidTo < DateTime.UtcNow.AddSeconds(10))
                        throw new Exception("Expired");
                }
                catch (Exception)
                {
                    throw new Exception("Invalid or expired token.");
                }

                AppData.Token = TokenParameter;
                NavManager.NavigateTo("search");
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAndResetAsync(ex.Message);
        }
    }
    
    private async Task PasteToken()
    {
        var (ok, value) = await JS.InvokeAsyncWithErrorHandling<string>("navigator.clipboard.readText");
        if (ok)
            _token = value;
    }
}
